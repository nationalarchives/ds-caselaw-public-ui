{% from "govuk_frontend_jinja/components/hint/macro.html" import govukHint %}
{% from "govuk_frontend_jinja/components/error-message/macro.html" import govukErrorMessage %}
{%- set describedby_ids = [] -%}
{%- if field.help_text -%}
  {%- set describedby_ids = describedby_ids + [field.auto_id + "_hint"] -%}
{%- endif -%}
{%- for error in field.errors -%}
  {%- set describedby_ids = describedby_ids + [field.auto_id + "_" + loop.index|string + "_error"] -%}
{%- endfor -%}
<fieldset class="govuk-fieldset"
          {% if describedby_ids %}aria-describedby="{{ describedby_ids | join(' ') }}"{% endif %}>
  {% if field.label %}
    <legend class="govuk-fieldset__legend{% if legend_size %} {{ legend_size }}{% endif %}">
      {% if legend_tag %}<{{ legend_tag }} class="govuk-fieldset__heading">{% endif %}
      {{ field.label | safe }}
      {% if legend_tag %}</{{ legend_tag }}>{% endif %}
    </legend>
  {% endif %}
  {% if field.help_text %}{{ govukHint({"text": field.help_text, "id": field.auto_id + "_hint"}) }}{% endif %}
  {% for error in field.errors %}
    {{ govukErrorMessage({"text": error, "id": field.auto_id + "_" + loop.index|string + "_error"}) }}
  {% endfor %}
  <div class="govuk-checkboxes{% if inline %}--inline{% endif %}{% if checkboxes_small %} govuk-checkboxes--small{% endif %}">
    {% for choice in field.choices %}
      {% set i = loop.index %}
      {% set choose_widget_name = widget.subwidgets[0].name %}
      <div class="govuk-checkboxes__item">
        <input type="checkbox"
               name="{{ choose_widget_name }}"
               class="govuk-checkboxes__input"
               id="id_{{ choose_widget_name }}_{{ i }}"
               value="{{ unlocalize(choice[0]) }}"
               {% if choice[0] in widget.subwidgets[0].value or (choice[0] | string) in widget.subwidgets[0].value %} checked="checked" {% endif %}
               {% if choice.hint %}aria-describedby="id_{{ choose_widget_name }}_{{ i }}_hint"{% endif %}>
        <label class="govuk-label govuk-checkboxes__label"
               for="id_{{ choose_widget_name }}_{{ i }}"
               id="id_{{ choose_widget_name }}_{{ i }}_label">{{ unlocalize(choice[1]) }}</label>
        {% if choice.hint %}
          <span id="id_{{ choose_widget_name }}_{{ i }}_hint"
                class="govuk-hint govuk-checkboxes__hint">{{ choice.hint }}</span>
        {% endif %}
        {% if has_other_field(i, other_fields) %}
          {% set subwidget = get_subwidget_for_other_field(i, other_field_subwidgets) %}
          {% set widget = subwidget %}
          {% set option_index = i %}
          {% include subwidget.template_name %}
        {% endif %}
      </div>
      {% if choice.divider %}<div class="govuk-checkboxes__divider">{{ choice.divider }}</div>{% endif %}
    {% endfor %}
  </div>
</fieldset>
