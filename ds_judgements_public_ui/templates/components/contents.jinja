{% from "components/heading.jinja" import heading %}
{% macro contents_container() %}
  <div class="contents-container">{{ caller() }}</div>
{% endmacro %}
{% macro contents(title=None, variant="default") %}
  {% set variant_classes = {"default": "contents", "unbordered": "contents contents--unbordered"} %}
  {% set variant_class = variant_classes.get(variant, variant_classes['default']) %}
  <nav class="{{ variant_class }}">
    <div class="contents__links">
      {% if title %}
        {% call heading(tag="div", size="h3") %}
          {{ title }}
        {% endcall %}
      {% endif %}
      {{ caller() }}
    </div>
  </nav>
{% endmacro %}
{% macro contents_examples() %}
  {% call contents(title="On this page") %}
    <ul>
      <li>
        <a href="#section-what">What Find Case Law does</a>
      </li>
      <li>
        <a href="#section-pages">Pages in this section</a>
      </li>
    </ul>
  {% endcall %}
{% endmacro %}
