{% macro navigation(active_endpoint=None) %}
  <input type="checkbox" id="navigation-toggle" class="navigation__toggle" />
  <label class="navigation__overlay"
         for="navigation-toggle"
         aria-hidden="true"></label>
  <nav class="navigation-container"
       aria-label="Navigation"
       role="navigation">
    <div class="navigation" tabindex="-1">
      <label class="navigation__menu-button" for="navigation-toggle">
        Menu {{ icon(name="chevron_down_white", size="xs") }}
      </label>
      <div class="container">
        <ul>
          {% for item in nav_items %}
            {% set is_active = (active_endpoint and item.endpoint == active_endpoint) %}
            <li class="{{ 'navigation__item--active' if is_active }} {% if item.children %}navigation__item--has-children{% endif %}">
              {% if item.children %}
                <input type="checkbox"
                       id="navigation-sub-{{ item.endpoint }}"
                       class="navigation__item-toggle" />
              {% endif %}
              <span class="navigation__item">
                {% if item.children %}
                  <label class="navigation__item-icon"
                         for="navigation-sub-{{ item.endpoint }}">
                    {{ icon(name="chevron_down_black", size="sm") }}
                    {{ icon(name="chevron_down_white", size="sm") }}
                    <span class="govuk-visually-hidden">Toggle navigation</span>
                  </label>
                {% endif %}
                {% call link(href=url(item.endpoint), variant="contrast") %}
                  <span class="navigation__item-label">{{ item.label }}</span>
                {% endcall %}
              </span>
              {% if item.children %}
                <ul>
                  {% for child in item.children %}
                    <li>
                      {% call link(href=url(child.endpoint)) %}
                        {{ child.label }}
                      {% endcall %}
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </nav>
{% endmacro %}
