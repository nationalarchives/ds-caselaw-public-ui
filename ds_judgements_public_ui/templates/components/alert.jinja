{% macro alert(title=None, variant="default", size="md") %}
  {% set variant_classes = {"default": "alert", "error": "alert alert--error", "success": "alert alert--success"} %}
  {% set size_classes = {"sm": "alert--sm", "md": "alert--md"} %}
  {% set variant_class = variant_classes.get(variant, variant_classes['default']) %}
  {% set size_class = size_classes.get(size, size_classes['md']) %}
  <div class="{{ variant_class }} {{ size_class }}">
    {% if title %}<h2 class="alert__heading">{{ title }}</h2>{% endif %}
    {{ caller() }}
  </div>
{% endmacro %}
