{% from "components/button.jinja" import button %}
{% if query_params and query_params.items %}
  <div class="result-controls result-controls--footer">
    <form method="get"
          action="{{ request.path }}"
          id="analytics-result-controls">
      {% for key, value in query_params.items() %}
        {% if value != none %}
          {% if key == "court" %}
            {% for court in value %}<input type="hidden" name="court" value="{{ court }}" />{% endfor %}
          {% elif key == "tribunal" %}
            {% for tribunal in value %}<input type="hidden" name="tribunal" value="{{ tribunal }}" />{% endfor %}
          {% elif key == "from" or key == "to" %}
            <input type="hidden"
                   name="{{ key }}"
                   value="{{ formatdate(value, '%Y-%b-%d') }}" />
          {% elif key != "order" or key != "per_page" %}
            <input type="hidden" name="{{ key }}" value="{{ value }}" />
          {% endif %}
        {% endif %}
      {% endfor %}
      <div class="result-controls__item">
        <label for="per_page" class="result-controls__label">Results per page</label>
        <select class="result-controls__select" name="per_page">
          <option value="10"
                  {% if per_page == 10 or per_page is none %}selected='selected'{% endif %}>10</option>
          <option value="25" {% if per_page == 25 %}selected='selected'{% endif %}>25</option>
          <option value="50" {% if per_page == 50 %}selected='selected'{% endif %}>50</option>
        </select>
      </div>
      {{ button(variant="secondary", size="small", element_type="input", attrs={"value": "Apply", "type":"submit"}) }}
    </form>
  </div>
{% endif %}
